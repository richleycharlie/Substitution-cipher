#include <stdio.h>
#include <cs50.h>
#include <string.h>
#include <ctype.h>
#include <stdlib.h>

bool is_member(char target_character, char arr[], int arr_length);
// Program works with assuming all are lowercase
// Need to make use of functions from ctype.h - tolower, toupper, islower, is upper

int main(int argc, string argv[])
{
    if (argc != 2)
    {
        printf("Wrong number of command line arguments. \n");
        return 1;
    }
    string key_string = argv[1];
    int key_length = strlen(key_string);
    if (key_length != 26)
    {
        printf("Error - invalid key: wrong number of characters. \n");
        return 1;
    }
    char key_array[26];
    for (int i = 0; i < key_length; i++)
    {
        char character = toupper(key_string[i]);
        if (isalpha(character))
        {
            int in_past = is_member(character, key_array, i);
            if (in_past == 0)
            {
                key_array[i] = character;
            }
            else
            {
                printf("Error - not all characters are unique. \n");
                return 1;
            }
        }
        else
        {
            printf("Error - invalid key: not all characters are alphabetical. \n");
            return 1;
        }
    }
    string plain_text = get_string("plaintext: ");
    int plain_length = strlen(plain_text);
    char cipher_arr[plain_length];
    printf("ciphertext: ");
    for (int i = 0; i < plain_length; i++)
    {
        char c = plain_text[i];
        if (isalpha(c))
        {
            bool is_lower = islower(c);
            if (is_lower == 1)
            {
                int current_character = plain_text[i] - 96;
                cipher_arr[i] = tolower(key_array[current_character - 1]);
            }
            else
            {
                int current_character = plain_text[i] - 64;
                cipher_arr[i] = toupper(key_array[current_character - 1]);
            }
            printf("%c", cipher_arr[i]);
        }
        else
        {
            cipher_arr[i] = plain_text[i];
            printf("%c", cipher_arr[i]);
        }
    }
    printf("\n");
    return 0;
}

bool is_member(char target_character, char arr[], int arr_length)
{
    for (int i = 0; i < arr_length; i++)
    {
        char current_character = arr[i];
        if (current_character == target_character)
        {
            return true;
        }
    }
    return false;
}
